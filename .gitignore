# Public mirror — generated by scripts/publish.mjs from the working repo.
# Anything checked-in here is intended for public distribution under AGPL-3.0.

# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Tests / coverage
playwright-report/
test-results/
playwright/.cache/
coverage/

# Linter / formatter caches
.eslintcache
.stylelintcache
.prettiercache
.cache/

# Build (defensive) — anchored to the mirror ROOT so a bare "build"/"dist"/"out"
# rule can never swallow a nested vendored directory. (A vendored lib ships its
# own build/ — e.g. vendor/pdfjs/legacy/build/pdf.min.mjs — and an unanchored
# "build/" rule silently dropped it from the push, 404ing the PDF engine.)
/dist/
/build/
/out/

# Logs / scratch / backup
*.log
*.tmp
*.bak
*.orig
*.rej
.tmp/
tmp/

# Secrets (defense in depth)
.env
.env.*
!.env.example
*.pem
*.key

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Editors
.idea/
.vscode/settings.json
*.swp
*~
